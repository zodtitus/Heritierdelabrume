JWT_SECRET=change-moi-par-une-vraie-clé-aléatoire

# Mot de passe pour l'interface admin
ADMIN_PASSWORD=ton-mot-de-passe-admin

# Webhook Discord (Paramètres du salon > Intégrations > Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
